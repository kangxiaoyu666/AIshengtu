# ==========================================
# 椒图AI 环境变量配置
# 复制此文件为 .env.local 并填入真实值
# ==========================================

# ---------- 微信支付（生产必填）----------
WECHAT_MERCHANT_ID=
WECHAT_APP_ID=
WECHAT_API_V3_KEY=
WECHAT_PRIVATE_KEY=
WECHAT_SERIAL_NO=
WECHAT_NOTIFY_URL=http://localhost:3000/api/pay/wechat/notify
# 测试模式：不填商户号时自动启用模拟支付
WECHAT_TEST_MODE=true

# ---------- 应用基础 ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- 管理员 ----------
ADMIN_TOKEN=jiaotu-admin-2025

# ---------- AI模型（选填）----------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ---------- 对象存储（选填）----------
OSS_ENDPOINT=
OSS_BUCKET=
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
